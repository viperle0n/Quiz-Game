<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuizGame.Views.ResultsPage"
             Title="Results">

    <Grid>
        <!-- Background image -->
        <Image Source="quizbackgroundimage.png"
               Aspect="AspectFill" />

        <!-- Scrollable content -->
        <ScrollView>
            <VerticalStackLayout Padding="30"
                                 Spacing="25"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <!-- Score & Accuracy -->
                <Label x:Name="ScoreLabel" FontSize="32" TextColor="Black" />
                <Label x:Name="PercentageLabel" FontSize="24" TextColor="Black" />

                <!-- Buttons -->
                <Button Text="Retry Quiz" Clicked="OnRetryClicked" />
                <Button Text="Return to Main Menu" Clicked="OnMainMenuClicked" />

                <!-- Leaderboard Title -->
                <Label Text="Leaderboard"
                       FontSize="28"
                       TextColor="Black"
                       HorizontalOptions="Center"
                       Margin="0,10" />

                <!-- Leaderboard Container -->
                <Frame BackgroundColor="Yellow"
                       CornerRadius="12"
                       HasShadow="True"
                       Padding="0"
                       WidthRequest="320"
                       HorizontalOptions="Center">

                    <CollectionView x:Name="LeaderboardView"
                                    HeightRequest="320"
                                    SelectionMode="None"
                                    ItemsSource="{Binding}">

                        <!-- Header -->
                        <CollectionView.Header>
                            <Grid Padding="10"
                                  BackgroundColor="#E0E0E0"
                                  ColumnDefinitions="40,*,60">
                                <Label Text="#" FontAttributes="Bold" />
                                <Label Text="Username" Grid.Column="1" FontAttributes="Bold" />
                                <Label Text="Score" Grid.Column="2" FontAttributes="Bold"
                                       HorizontalTextAlignment="End" />
                            </Grid>
                        </CollectionView.Header>

                        <!-- Items -->
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10"
                                      ColumnDefinitions="40,*,60"
                                      RowSpacing="0">
                                    <Label Text="{Binding Rank}" TextColor="Black" />
                                    <Label Text="{Binding Username}" TextColor="Black" Grid.Column="1" />
                                    <Label Text="{Binding Highscore}" TextColor="Black" Grid.Column="2"
                                           HorizontalTextAlignment="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>